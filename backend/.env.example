# BothSafe Backend Environment Configuration
# Copy this file to .env and fill in real values

# API & Server
API_URL=http://localhost:3001
NODE_ENV=development
PORT=3003

# Database (PostgreSQL via Docker)
DATABASE_URL=postgresql://bothsafe:bothsafe@localhost:5432/bothsafe?schema=public

# Redis
REDIS_URL=redis://localhost:6379

# Secrets (generate strong random values)
JWT_SECRET=replace_with_32_plus_random_chars_jwt_secret_value_here
SESSION_SECRET=replace_with_32_plus_random_chars_session_secret
ENCRYPTION_MASTER_KEY=base64_32_byte_key_here

# Application
APP_BASE_URL=http://localhost:3000
INVITE_TOKEN_TTL_HOURS=72
DEAL_EXPIRES_HOURS=720
PLATFORM_FEE_PERCENT=2
DEFAULT_CURRENCY=USD
RECEIVER_ACCOUNT_LABEL="BothSafe Escrow (Bakong)"

# Bakong / KHQR — Register at https://bakong.nbc.gov.kh
BAKONG_ACCOUNT_ID=your_bakong_account@aba
BAKONG_MERCHANT_NAME=BothSafe Escrow
BAKONG_MERCHANT_CITY=Phnom Penh
BAKONG_API_TOKEN=your_bakong_api_token

# CORS — comma-separated allowlist (empty = allow all in dev)
CORS_ORIGINS=

# Telegram Bot (from BotFather)
TELEGRAM_BOT_TOKEN=your_bot_token
TELEGRAM_WEBHOOK_SECRET=replace_with_random_string
TELEGRAM_WEBHOOK_URL=http://localhost:3001/webhooks/telegram
TELEGRAM_BOT_USERNAME=YourBotUsername
TELEGRAM_BOT_ENABLED=false

# Admin bootstrap credentials (only used on first run)
ADMIN_BOOTSTRAP_EMAIL=admin@bothsafe.local
ADMIN_BOOTSTRAP_PASSWORD=change_me_strong_password

# Google OAuth — https://console.cloud.google.com/apis/credentials
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret

# Telegram OIDC — Bot Settings → Web Login in BotFather
TELEGRAM_CLIENT_ID=your_bot_numeric_id
TELEGRAM_CLIENT_SECRET=your_telegram_client_secret

# Auth callbacks
AUTH_CALLBACK_BASE_URL=http://localhost:3003

# Session
SESSION_TTL_DAYS=30

# Logging (optional)
# LOG_LEVEL=info          # debug | info | warn | error
# LOGS_DIR=./logs         # directory for daily rotated log files
